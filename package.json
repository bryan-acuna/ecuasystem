{
  "name": "ecuasystems",
  "version": "1.0.0",
  "description": "",
  "main": "backend/index.ts",
  "scripts": {
    "start": "tsx backend/index.ts",
    "server": "tsx watch backend/index.ts",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "typecheck:backend": "tsc --noEmit -p backend/tsconfig.json",
    "build": "npm install && npx prisma generate && npm install --prefix frontend --include=dev && npm run build --prefix frontend",
    "seed": "tsx backend/seed.ts",
    "test:db": "tsx backend/testConnection.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bryan-acuna/ecuasystem.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/bryan-acuna/ecuasystem/issues"
  },
  "homepage": "https://github.com/bryan-acuna/ecuasystem#readme",
  "dependencies": {
    "@prisma/client": "^6.17.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "prisma": "^6.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
